<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>dynamische dateinseite</title>
</head>
<body>
<ul id="liste-linz"></ul> 
<script>
  // Lokale Daten
  const stadtteile = ["Urfahr", "Innere Stadt", "Bindermichel"];
  const liste = document.getElementById("liste-linz");
  stadtteile.forEach(s => {
    let li = document.createElement("li");
    li.textContent = s;
    liste.appendChild(li);
  });
</script>
